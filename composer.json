{
    "name": "kejubayer/redx-api-integration",
    "description": "Laravel package for integrating the RedX API and storing RedX webhook requests.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kejubayer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Kejubayer\\RedxApiIntegration\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kejubayer\\RedxApiIntegration\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kejubayer\\RedxApiIntegration\\RedxApiIntegrationServiceProvider"
            ],
            "aliases": {
                "Redx": "Kejubayer\\RedxApiIntegration\\Facades\\Redx"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
